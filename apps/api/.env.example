# BookIt API — Environment Variables
# Copy this to .env and fill in your values

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─── Database (Direct PostgreSQL connection) ─────────────────
DATABASE_URL=your_supabase_postgres_connection_string

# ─── Redis (Upstash free tier) ───────────────────────────────
REDIS_URL=your_upstash_redis_url
REDIS_TOKEN=your_upstash_redis_token

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP (using Supabase Auth built-in SMS) ──────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ─── Twilio / WATI (WhatsApp) ────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@bookit.in

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://bookit.in

# ─── Cloudflare R2 (File Storage) ────────────────────────────
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=bookit-assets
R2_PUBLIC_URL=https://assets.bookit.in
